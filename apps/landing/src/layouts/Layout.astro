---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "PadelHub — Llena tus canchas con jugadores reales",
  description = "PadelHub conecta tu local con miles de jugadores buscando dónde jugar. Gestiona reservas, canchas y horarios desde un solo dashboard.",
} = Astro.props;
---

<!doctype html>
<html lang="es" data-audience="player">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#3B82F6" />
    <link rel="canonical" href={Astro.url} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_PE" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content={new URL("/images/og-image.png", Astro.site ?? Astro.url).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL("/images/og-image.png", Astro.site ?? Astro.url).href} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Sora:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Favicons -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
    <script is:inline>
      (function () {
        var orgAnchors = ["solicitar", "organizaciones", "features", "comparacion"];
        var hash = location.hash.replace("#", "");
        if (orgAnchors.indexOf(hash) !== -1) {
          document.documentElement.dataset.audience = "org";
        }
      })();
    </script>
  </head>
  <body class="bg-white text-gray-900 overflow-x-hidden font-sans">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only fixed top-4 left-4 z-[100] rounded-lg bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-lg focus:outline-none"
    >
      Saltar al contenido
    </a>
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

<!-- Audience & navbar CSS — kept outside Tailwind pipeline to avoid tree-shaking -->
<style is:global>
  /* Audience-driven section visibility */
  html[data-audience="player"] [data-for="org"] {
    display: none;
  }
  html[data-audience="org"] [data-for="player"] {
    display: none;
  }

  /* Navbar scroll state */
  html[data-scrolled] #navbar {
    background-color: rgb(255 255 255 / 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid #e5e7eb;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
  }

  /* Nav link colors: player audience, not scrolled (dark hero) */
  html[data-audience="player"]:not([data-scrolled]) .nav-link {
    color: rgb(255 255 255 / 0.85);
  }
  html[data-audience="player"]:not([data-scrolled]) .nav-link:hover {
    color: white;
  }

  /* Nav link colors: org audience or scrolled (light bg) */
  html[data-audience="org"]:not([data-scrolled]) .nav-link,
  html[data-scrolled] .nav-link {
    color: #4b5563;
  }
  html[data-audience="org"]:not([data-scrolled]) .nav-link:hover,
  html[data-scrolled] .nav-link:hover {
    color: #111827;
  }

  /* Logo swap: default = colored logo; player + not scrolled = white logo */
  #navbar-logo-reversed {
    display: none;
  }
  html[data-audience="player"]:not([data-scrolled]) #navbar-logo-default {
    display: none;
  }
  html[data-audience="player"]:not([data-scrolled]) #navbar-logo-reversed {
    display: block;
  }

  /* Buscar Canchas button: glass variant on dark hero */
  html[data-audience="player"]:not([data-scrolled]) .nav-btn-search {
    background-color: rgb(255 255 255 / 0.1);
    border-color: rgb(255 255 255 / 0.2);
    color: white;
  }
  html[data-audience="player"]:not([data-scrolled]) .nav-btn-search:hover {
    background-color: rgb(255 255 255 / 0.18);
  }
</style>
