---
const problems = [
  {
    icon: "📱",
    title: "Dependes de WhatsApp",
    description:
      "Reservas por mensaje, sin control ni historial. Se pierden clientes por respuestas tardias.",
  },
  {
    icon: "👻",
    title: "Jugadores invisibles",
    description:
      "Miles de jugadores buscan cancha y no saben que existes. Solo te llegan los que ya te conocen.",
  },
  {
    icon: "📊",
    title: "Cero visibilidad",
    description:
      "No sabes tu ocupacion real, no puedes optimizar precios, ni saber cuanto dejas en la mesa.",
  },
];

const solutions = [
  {
    icon: "🚀",
    title: "Reservas automaticas 24/7",
    description:
      "Los jugadores reservan directo desde la app. Sin mensajes, sin llamadas, sin demoras.",
  },
  {
    icon: "🎯",
    title: "Demanda que llega sola",
    description:
      "Tu local aparece frente a cientos de jugadores activos buscando cancha en tu zona.",
  },
  {
    icon: "📈",
    title: "Dashboard completo",
    description:
      "Reservas, ingresos, ocupacion, horarios pico — toda la data que necesitas para crecer.",
  },
];
---

<section class="relative overflow-hidden bg-gray-900 px-8 py-24">
  <!-- Decorative bg -->
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_20%_50%,rgba(59,130,246,0.08)_0%,transparent_50%),radial-gradient(ellipse_at_80%_50%,rgba(16,185,129,0.06)_0%,transparent_50%)]"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-[1200px]">
    <!-- Header -->
    <div class="mx-auto mb-16 max-w-[700px] text-center">
      <div
        class="mb-4 text-[13px] font-semibold tracking-[2px] text-primary uppercase"
      >
        El problema
      </div>
      <h2 class="font-display text-3xl font-bold leading-tight text-white lg:text-[40px]">
        Tus canchas vacias no generan ingresos
      </h2>
    </div>

    <!-- Grid -->
    <div class="grid items-start gap-8 lg:grid-cols-[1fr_48px_1fr] lg:gap-0">
      <!-- Problem column -->
      <div class="flex flex-col gap-5">
        <div
          class="mb-2 border-b border-white/10 pb-4 font-display text-sm font-semibold tracking-[2px] text-[#F87171] uppercase"
        >
          ❌ Sin PadelHub
        </div>
        {
          problems.map((item) => (
            <div class="flex gap-3.5 rounded-xl border border-[rgba(248,113,113,0.1)] bg-[rgba(248,113,113,0.06)] p-5">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-[10px] bg-[rgba(248,113,113,0.12)] text-base">
                {item.icon}
              </div>
              <div>
                <h4 class="mb-1 text-[15px] font-semibold text-white">
                  {item.title}
                </h4>
                <p class="text-[13px] leading-relaxed text-gray-400">
                  {item.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>

      <!-- VS divider -->
      <div class="hidden items-center justify-center self-center lg:flex">
        <div
          class="flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-primary to-[#6366F1] font-display text-xs font-bold tracking-wider text-white"
        >
          VS
        </div>
      </div>

      <!-- Solution column -->
      <div class="flex flex-col gap-5">
        <div
          class="mb-2 border-b border-white/10 pb-4 font-display text-sm font-semibold tracking-[2px] text-secondary uppercase"
        >
          ✅ Con PadelHub
        </div>
        {
          solutions.map((item) => (
            <div class="flex gap-3.5 rounded-xl border border-[rgba(16,185,129,0.1)] bg-[rgba(16,185,129,0.06)] p-5">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-[10px] bg-[rgba(16,185,129,0.12)] text-base">
                {item.icon}
              </div>
              <div>
                <h4 class="mb-1 text-[15px] font-semibold text-white">
                  {item.title}
                </h4>
                <p class="text-[13px] leading-relaxed text-gray-400">
                  {item.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
