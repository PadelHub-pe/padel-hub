<section class="bg-white px-8 py-24">
  <div class="mx-auto max-w-[600px] text-center">
    <h2
      class="mb-4 font-display text-3xl font-bold tracking-tight text-gray-900 lg:text-[40px]"
    >
      ¿Listo para jugar?
    </h2>
    <p class="mb-10 text-[17px] leading-relaxed text-gray-500">
      Encuentra canchas disponibles en tu distrito y reserva en segundos. Sin
      cuenta, sin comision.
    </p>
    <a
      href="https://bookings.padelhub.pe"
      class="inline-flex items-center gap-2 rounded-[14px] bg-secondary px-8 py-4 text-base font-semibold text-white shadow-[0_4px_16px_rgba(16,185,129,0.3)] transition-all hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(16,185,129,0.35)] no-underline"
    >
      Buscar Canchas
      <svg
        width="16"
        height="16"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        viewBox="0 0 24 24"
      >
        <path d="M5 12h14M12 5l7 7-7 7"></path>
      </svg>
    </a>
  </div>
</section>
