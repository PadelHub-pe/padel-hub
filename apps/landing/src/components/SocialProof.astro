<section class="border-y border-gray-100 bg-white px-8 py-12">
  <div class="mx-auto max-w-[1200px] text-center">
    <div
      class="mb-8 text-[13px] font-medium tracking-[1.5px] text-gray-400 uppercase"
    >
      La plataforma de padel que esta creciendo en Lima
    </div>
    <div class="grid grid-cols-2 gap-6 lg:grid-cols-4 lg:gap-10">
      <div class="text-center">
        <div
          class="font-display text-4xl font-extrabold tracking-tight text-gray-900"
        >
          <span class="text-primary">500+</span>
        </div>
        <div class="mt-1 text-sm text-gray-500">Jugadores registrados</div>
      </div>
      <div class="text-center">
        <div
          class="font-display text-4xl font-extrabold tracking-tight text-gray-900"
        >
          12
        </div>
        <div class="mt-1 text-sm text-gray-500">Locales asociados</div>
      </div>
      <div class="text-center">
        <div
          class="font-display text-4xl font-extrabold tracking-tight text-gray-900"
        >
          <span class="text-primary">2,400+</span>
        </div>
        <div class="mt-1 text-sm text-gray-500">Reservas procesadas</div>
      </div>
      <div class="text-center">
        <div
          class="font-display text-4xl font-extrabold tracking-tight text-gray-900"
        >
          4.8<span class="text-xl text-warning">★</span>
        </div>
        <div class="mt-1 text-sm text-gray-500">Rating promedio</div>
      </div>
    </div>
  </div>
</section>
