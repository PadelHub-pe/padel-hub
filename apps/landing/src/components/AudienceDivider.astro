---

<section class="relative overflow-hidden bg-gradient-to-b from-white to-gray-50 px-8 py-20">
  <div class="mx-auto max-w-[1200px] text-center">
    <!-- Decorative line -->
    <div class="mx-auto mb-8 h-px w-24 bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

    <!-- Badge -->
    <div
      class="mx-auto mb-5 inline-flex items-center gap-2 rounded-full border border-primary-200 bg-primary-50 px-4 py-1.5"
    >
      <span class="text-[13px] font-semibold tracking-wide text-primary">Para propietarios de canchas</span>
    </div>

    <!-- Heading -->
    <h2
      class="mx-auto max-w-[520px] font-display text-2xl font-bold tracking-tight text-gray-900 lg:text-[32px]"
    >
      Potencia tu negocio de padel
    </h2>
    <p class="mx-auto mt-3 max-w-[440px] text-[15px] leading-relaxed text-gray-500">
      Herramientas profesionales para llenar tus canchas y simplificar tu operacion.
    </p>

    <!-- Decorative line -->
    <div class="mx-auto mt-8 h-px w-24 bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>
  </div>
</section>
