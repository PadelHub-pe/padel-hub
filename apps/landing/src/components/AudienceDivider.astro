<section class="relative overflow-hidden bg-gradient-to-b from-white via-[#F0F7FF] to-white px-8 py-20">
  <div class="mx-auto max-w-[600px] text-center">
    <div
      class="mb-4 inline-flex items-center gap-2 rounded-full border border-primary-200 bg-primary-50 px-4 py-1.5 text-[13px] font-semibold text-primary-800"
    >
      <svg
        class="h-4 w-4"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <path
          d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0h2m-16 0H3m2 4h14"
        ></path>
