---
const steps = [
  {
    number: 1,
    icon: "🔍",
    title: "Descubre",
    description:
      "Explora canchas de padel en tu distrito. Filtra por tipo, precio y amenidades.",
    numberBg: "bg-secondary-100",
    numberColor: "text-secondary-800",
  },
  {
    number: 2,
    icon: "📅",
    title: "Reserva",
    description:
      "Elige el horario que prefieras y reserva tu cancha en segundos. Sin llamadas.",
    numberBg: "bg-primary-100",
    numberColor: "text-primary",
  },
  {
    number: 3,
    icon: "🎾",
    title: "Juega",
    description:
      "Llega a la cancha y disfruta tu partido. Encuentra jugadores de tu nivel.",
    numberBg: "bg-warning-light",
    numberColor: "text-warning-dark",
  },
];
---

<section class="bg-gray-50 px-8 py-24" id="jugadores">
  <div class="mx-auto max-w-[1200px]">
    <!-- Header -->
    <div class="mx-auto mb-[72px] max-w-[600px] text-center">
      <div
        class="mb-4 text-[13px] font-semibold tracking-[2px] text-secondary-800 uppercase"
      >
        Para Jugadores
      </div>
      <h2
        class="mb-4 font-display text-3xl font-bold tracking-tight text-gray-900 lg:text-[40px]"
      >
        Reserva en 3 simples pasos
      </h2>
      <p class="text-[17px] text-gray-500">
        Sin llamadas, sin esperas. Encuentra y reserva tu cancha favorita en
        minutos.
      </p>
    </div>

    <!-- Steps -->
    <div class="relative grid grid-cols-1 gap-10 lg:grid-cols-3 lg:gap-0">
      <!-- Connecting line (desktop only) -->
      <div
        class="pointer-events-none absolute top-11 right-[16.66%] left-[16.66%] hidden h-0.5 bg-gradient-to-r from-secondary to-primary opacity-20 lg:block"
      >
      </div>

      <!-- Mobile connecting line -->
      <div
        class="pointer-events-none absolute top-0 bottom-0 left-1/2 w-0.5 -translate-x-1/2 bg-gradient-to-b from-secondary to-primary opacity-10 lg:hidden"
      >
      </div>

      {
        steps.map((step) => (
          <div class="relative px-8 text-center">
            <div
              class={`relative z-10 mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-2xl font-display text-[22px] font-bold ${step.numberBg} ${step.numberColor}`}
            >
              {step.number}
            </div>
            <div class="mb-4 text-[32px]">{step.icon}</div>
            <h3 class="mb-2 font-display text-lg font-semibold text-gray-900">
              {step.title}
            </h3>
            <p class="text-sm leading-relaxed text-gray-500">
              {step.description}
            </p>
          </div>
        ))
      }
    </div>

    <!-- CTA -->
    <div class="mt-16 text-center">
      <a
        href="https://bookings.padelhub.pe"
        class="inline-flex items-center gap-2 rounded-[14px] bg-secondary px-8 py-4 text-base font-semibold text-white shadow-[0_4px_16px_rgba(16,185,129,0.3)] transition-all hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(16,185,129,0.35)]"
      >
        Buscar Canchas
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path
            fill-rule="evenodd"
            d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
            clip-rule="evenodd"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
