---
const testimonials = [
  {
    initials: "CM",
    name: "Carlos M.",
    location: "Miraflores",
    category: "Cat 4",
    quote:
      "Antes perdia media hora llamando a cada club para ver disponibilidad. Ahora comparo precios y horarios en un solo lugar y reservo en segundos.",
    gradient: "from-primary to-[#6366F1]",
  },
  {
    initials: "ML",
    name: "Maria L.",
    location: "San Isidro",
    category: "Cat 5",
    quote:
      "Lo que mas me gusta es que no necesito descargar nada ni crear cuenta. Entro, elijo mi cancha y listo. Super practico para alguien que recien empieza.",
    gradient: "from-secondary to-[#059669]",
  },
  {
    initials: "RS",
    name: "Roberto S.",
    location: "Surco",
    category: "Cat 3",
    quote:
      "Juego 3 veces por semana en distintos clubes. PadelHub me permite ver todas las opciones en mi zona sin tener que revisar 5 paginas de Instagram.",
    gradient: "from-warning to-[#D97706]",
  },
  {
    initials: "AP",
    name: "Ana P.",
    location: "La Molina",
    category: "Cat 6",
    quote:
      "Empece a jugar padel hace poco y no conocia ningun club. Gracias a PadelHub encontre una cancha cerca de mi casa con horarios que me funcionan perfecto.",
    gradient: "from-[#EC4899] to-[#8B5CF6]",
  },
];
---

<section class="bg-gray-50 px-8 py-24">
  <div class="mx-auto max-w-[1200px]">
    <!-- Header -->
    <div class="mx-auto mb-16 max-w-[600px] text-center">
      <div
        class="mb-4 text-[13px] font-semibold tracking-[2px] text-secondary uppercase"
      >
        Testimonios
      </div>
      <h2
        class="mb-4 font-display text-3xl font-bold leading-tight tracking-tight text-gray-900 lg:text-[40px]"
      >
        Lo que dicen nuestros jugadores
      </h2>
      <p class="text-[17px] leading-relaxed text-gray-500">
        Jugadores de toda Lima ya usan PadelHub para encontrar y reservar sus
        canchas favoritas.
      </p>
    </div>

    <!-- Desktop: 4-column grid -->
    <div class="hidden gap-6 md:grid md:grid-cols-2 lg:grid-cols-4">
      {
        testimonials.map((t, i) => (
          <div
            class="animate-fade-in-up group relative overflow-hidden rounded-[20px] border border-gray-200 bg-white p-7 transition-all duration-300 hover:-translate-y-1 hover:border-secondary hover:shadow-[0_8px_32px_rgba(16,185,129,0.08)]"
            style={`animation-delay: ${i * 0.1}s`}
          >
            {/* Stars */}
            <div class="mb-4 flex gap-0.5">
              {Array.from({ length: 5 }).map(() => (
                <svg
                  class="h-4 w-4 text-warning"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            {/* Quote */}
            <p class="mb-6 text-sm leading-relaxed text-gray-600">
              "{t.quote}"
            </p>

            {/* Author */}
            <div class="flex items-center gap-3">
              <div
                class={`flex h-10 w-10 items-center justify-center rounded-[12px] bg-gradient-to-br ${t.gradient} text-xs font-bold text-white`}
              >
                {t.initials}
              </div>
              <div>
                <div class="text-[14px] font-semibold text-gray-900">
                  {t.name}
                </div>
                <div class="text-[12px] text-gray-500">
                  {t.location} · {t.category}
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Mobile: horizontal scroll-snap carousel -->
    <div class="md:hidden">
      <div
        class="testimonial-carousel flex snap-x snap-mandatory gap-4 overflow-x-auto pb-6"
      >
        {
          testimonials.map((t) => (
            <div class="w-[85vw] max-w-[320px] flex-shrink-0 snap-center rounded-[20px] border border-gray-200 bg-white p-7">
              {/* Stars */}
              <div class="mb-4 flex gap-0.5">
                {Array.from({ length: 5 }).map(() => (
                  <svg
                    class="h-4 w-4 text-warning"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>

              {/* Quote */}
              <p class="mb-6 text-sm leading-relaxed text-gray-600">
                "{t.quote}"
              </p>

              {/* Author */}
              <div class="flex items-center gap-3">
                <div
                  class={`flex h-10 w-10 items-center justify-center rounded-[12px] bg-gradient-to-br ${t.gradient} text-xs font-bold text-white`}
                >
                  {t.initials}
                </div>
                <div>
                  <div class="text-[14px] font-semibold text-gray-900">
                    {t.name}
                  </div>
                  <div class="text-[12px] text-gray-500">
                    {t.location} · {t.category}
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Dot indicators -->
      <div class="mt-2 flex justify-center gap-2">
        {
          testimonials.map((_, i) => (
            <div
              class:list={[
                "h-2 rounded-full transition-all",
                i === 0 ? "w-6 bg-secondary" : "w-2 bg-gray-300",
              ]}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../styles/global.css";

  .testimonial-carousel {
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .testimonial-carousel::-webkit-scrollbar {
    display: none;
  }
</style>
