---

---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 py-4 transition-all duration-300"
>
  <div class="mx-auto flex max-w-[1200px] items-center justify-between px-4 sm:px-8">
    <a href="/" class="flex items-center no-underline">
      <img
        src="/images/logo-horizontal.svg"
        alt="PadelHub"
        class="h-9"
      />
    </a>

    <ul class="hidden items-center gap-8 lg:flex" role="list">
      <li>
        <a
          href="#jugadores"
          class="text-sm font-medium text-gray-600 no-underline transition-colors hover:text-gray-900"
          >Para Jugadores</a
        >
      </li>
      <li>
        <a
          href="#organizaciones"
          class="text-sm font-medium text-gray-600 no-underline transition-colors hover:text-gray-900"
          >Para Organizaciones</a
        >
      </li>
      <li>
        <a
          href="#comparacion"
          class="text-sm font-medium text-gray-600 no-underline transition-colors hover:text-gray-900"
          >Comparacion</a
        >
      </li>
    </ul>

    <div class="flex items-center gap-3">
      <a
        href="/login"
        class="hidden rounded-lg px-4 py-2 text-sm font-medium text-gray-700 no-underline transition-all hover:bg-gray-100 lg:inline-block"
        >Iniciar sesion</a
      >
      <a
        href="https://bookings.padelhub.pe"
        class="hidden rounded-[10px] border border-secondary bg-secondary-50 px-5 py-2.5 text-sm font-semibold text-secondary-800 no-underline transition-all hover:-translate-y-px hover:bg-secondary-100 hover:shadow-lg md:inline-block"
        >Buscar Canchas</a
      >
      <a
        href="#solicitar"
        class="rounded-[10px] bg-primary px-3.5 py-2 text-xs font-semibold text-white no-underline transition-all hover:-translate-y-px hover:bg-primary-600 hover:shadow-lg sm:px-5 sm:py-2.5 sm:text-sm"
        >Solicitar Acceso</a
      >
    </div>
  </div>
</nav>

<script>
  window.addEventListener("scroll", () => {
    const navbar = document.getElementById("navbar");
    if (!navbar) return;
    if (window.scrollY > 50) {
      navbar.classList.add(
        "bg-white/92",
        "backdrop-blur-xl",
        "border-b",
        "border-gray-200",
        "py-3",
      );
      navbar.classList.remove("py-4");
    } else {
      navbar.classList.remove(
        "bg-white/92",
        "backdrop-blur-xl",
        "border-b",
        "border-gray-200",
        "py-3",
      );
      navbar.classList.add("py-4");
    }
  });
</script>
