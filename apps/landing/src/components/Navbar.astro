---

---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 py-4 transition-all duration-300"
>
  <div class="mx-auto flex max-w-[1200px] items-center justify-between px-4 sm:px-8">
    <a href="/" class="flex items-center no-underline">
      <img
        src="/images/logo-horizontal.svg"
        alt="PadelHub"
        class="h-9"
        id="navbar-logo-default"
      />
      <img
        src="/images/logo-horizontal-reversed.svg"
        alt="PadelHub"
        class="h-9"
        id="navbar-logo-reversed"
      />
    </a>

    <ul class="hidden items-center gap-8 lg:flex" role="list">
      <li>
        <a
          href="#"
          id="nav-players"
          class="nav-link text-sm font-medium no-underline transition-colors"
          >Para Jugadores</a
        >
      </li>
      <li>
        <a
          href="#"
          id="nav-orgs"
          class="nav-link text-sm font-medium no-underline transition-colors"
          >Para Organizaciones</a
        >
      </li>
      <li data-for="org">
        <a
          href="#comparacion"
          class="nav-link text-sm font-medium no-underline transition-colors"
          >Comparacion</a
        >
      </li>
    </ul>

    <div class="flex items-center gap-3">
      <a
        href="/login"
        class="nav-link hidden rounded-lg px-4 py-2 text-sm font-medium no-underline transition-all hover:bg-gray-100/50 lg:inline-block"
        >Iniciar sesion</a
      >
      <a
        href="#canchas"
        id="nav-canchas"
        class="nav-btn-search hidden rounded-[10px] border border-secondary bg-secondary-50 px-5 py-2.5 text-sm font-semibold text-secondary-800 no-underline transition-all hover:-translate-y-px hover:shadow-lg md:inline-block"
        >Ver Canchas</a
      >
      <a
        href="#solicitar"
        id="nav-solicitar"
        class="rounded-[10px] bg-primary px-3.5 py-2 text-xs font-semibold text-white no-underline transition-all hover:-translate-y-px hover:bg-primary-600 hover:shadow-lg sm:px-5 sm:py-2.5 sm:text-sm"
        >Solicitar Acceso</a
      >
    </div>
  </div>
</nav>

<script>
  // Scroll detection — set data-scrolled on <html>
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      document.documentElement.dataset.scrolled = "true";
    } else {
      delete document.documentElement.dataset.scrolled;
    }
  });

  // Audience switch via navbar links
  document.getElementById("nav-players")?.addEventListener("click", (e) => {
    e.preventDefault();
    window.dispatchEvent(
      new CustomEvent("audience-switch", {
        detail: { audience: "player" },
      }),
    );
    window.scrollTo({ top: 0, behavior: "smooth" });
  });

  document.getElementById("nav-orgs")?.addEventListener("click", (e) => {
    e.preventDefault();
    window.dispatchEvent(
      new CustomEvent("audience-switch", {
        detail: { audience: "org" },
      }),
    );
    window.scrollTo({ top: 0, behavior: "smooth" });
  });

  // "Ver Canchas" navbar link should switch to player audience and scroll to directory
  document.getElementById("nav-canchas")?.addEventListener("click", (e) => {
    e.preventDefault();
    const html = document.documentElement;
    if (html.dataset.audience !== "player") {
      window.dispatchEvent(
        new CustomEvent("audience-switch", {
          detail: { audience: "player" },
        }),
      );
    }
    setTimeout(() => {
      document
        .getElementById("canchas")
        ?.scrollIntoView({ behavior: "smooth" });
    }, 50);
  });

  // "Solicitar Acceso" navbar link should also switch to org audience
  document.getElementById("nav-solicitar")?.addEventListener("click", (e) => {
    e.preventDefault();
    const html = document.documentElement;
    if (html.dataset.audience !== "org") {
      window.dispatchEvent(
        new CustomEvent("audience-switch", {
          detail: { audience: "org" },
        }),
      );
    }
    // Small delay so org sections render before scrolling to anchor
    setTimeout(() => {
      document
        .getElementById("solicitar")
        ?.scrollIntoView({ behavior: "smooth" });
    }, 50);
  });
</script>
