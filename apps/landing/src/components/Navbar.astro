---

---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 py-4 transition-all duration-300"
>
  <div class="mx-auto flex max-w-[1200px] items-center justify-between px-8">
    <a href="/" class="flex items-center no-underline">
      <img
        src="/images/logo-horizontal.svg"
        alt="PadelHub"
        class="h-9"
      />
    </a>

    <ul class="hidden items-center gap-8 md:flex" role="list">
      <li>
        <a
          href="#features"
          class="text-sm font-medium text-gray-600 no-underline transition-colors hover:text-gray-900"
          >Funcionalidades</a
        >
      </li>
      <li>
        <a
          href="#como-funciona"
          class="text-sm font-medium text-gray-600 no-underline transition-colors hover:text-gray-900"
          >Como funciona</a
        >
      </li>
      <li>
        <a
          href="#comparacion"
          class="text-sm font-medium text-gray-600 no-underline transition-colors hover:text-gray-900"
          >Comparacion</a
        >
      </li>
    </ul>

    <div class="flex items-center gap-3">
      <a
        href="/login"
        class="hidden rounded-lg px-4 py-2 text-sm font-medium text-gray-700 no-underline transition-all hover:bg-gray-100 sm:inline-block"
        >Iniciar sesion</a
      >
      <a
        href="#solicitar"
        class="rounded-[10px] bg-primary px-5 py-2.5 text-sm font-semibold text-white no-underline transition-all hover:-translate-y-px hover:bg-primary-600 hover:shadow-lg"
        >Solicitar Acceso</a
      >
    </div>
  </div>
</nav>

<script>
  window.addEventListener("scroll", () => {
    const navbar = document.getElementById("navbar");
    if (!navbar) return;
    if (window.scrollY > 50) {
      navbar.classList.add(
        "bg-white/92",
        "backdrop-blur-xl",
        "border-b",
        "border-gray-200",
        "py-3",
      );
      navbar.classList.remove("py-4");
    } else {
      navbar.classList.remove(
        "bg-white/92",
        "backdrop-blur-xl",
        "border-b",
        "border-gray-200",
        "py-3",
      );
      navbar.classList.add("py-4");
    }
  });
</script>
