---
const smallFeatures = [
  {
    icon: "📅",
    title: "Horarios y calendario",
    description:
      "Configura horarios de apertura, horas pico y dias especiales. Vista de calendario por dia y semana con zonas visuales.",
  },
  {
    icon: "💰",
    title: "Precios dinamicos",
    description:
      "Define precios base y markups por hora pico. Calculadora de ingresos estimados por ocupacion.",
  },
  {
    icon: "🏟️",
    title: "Gestion de canchas",
    description:
      "Administra hasta 10 canchas por local. Tipo de cancha, estado, imagenes y precios individuales.",
  },
  {
    icon: "👥",
    title: "Equipo y roles",
    description:
      "Invita a tu equipo con roles definidos. Org Admins ven todo, los managers solo sus locales asignados.",
  },
  {
    icon: "🏢",
    title: "Multi-local",
    description:
      "¿Tienes mas de una sede? Gestiona todas desde un solo panel con switching instantaneo entre locales.",
  },
];

const bookingPreview = [
  {
    initials: "ML",
    name: "Martin Lopez",
    meta: "Cancha 1 · Hoy 18:00–19:30 · 4 jugadores",
    status: "Confirmada",
    statusType: "confirmed" as const,
    gradient: "from-primary to-[#6366F1]",
  },
  {
    initials: "AS",
    name: "Ana Solis",
    meta: "Cancha 2 · Hoy 19:00–20:30 · 2 jugadores",
    status: "Pendiente",
    statusType: "pending" as const,
    gradient: "from-secondary to-[#059669]",
  },
  {
    initials: "CR",
    name: "Carlos Reyes",
    meta: "Cancha 1 · Manana 08:00–09:30 · 4 jugadores",
    status: "Confirmada",
    statusType: "confirmed" as const,
    gradient: "from-warning to-[#D97706]",
  },
];
---

<section class="bg-gray-50 px-8 py-24" id="features">
  <div class="mx-auto max-w-[1200px]">
    <!-- Header -->
    <div class="mx-auto mb-16 max-w-[600px] text-center">
      <div
        class="mb-4 text-[13px] font-semibold tracking-[2px] text-primary uppercase"
      >
        Funcionalidades
      </div>
      <h2
        class="mb-4 font-display text-3xl font-bold leading-tight tracking-tight text-gray-900 lg:text-[40px]"
      >
        Todo lo que necesitas para gestionar tu local
      </h2>
      <p class="text-[17px] leading-relaxed text-gray-500">
        Un dashboard profesional disenado especificamente para operadores de
        padel. Sin complejidad innecesaria.
      </p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      <!-- Featured card -->
      <div
        class="group relative col-span-1 row-span-1 overflow-hidden rounded-[20px] border border-transparent bg-gradient-to-br from-gray-900 to-gray-800 p-8 transition-all duration-300 hover:border-primary md:col-span-2 md:row-span-2"
      >
        <div
          class="mb-3 inline-block rounded-md bg-[rgba(59,130,246,0.15)] px-2.5 py-1 text-[11px] font-semibold text-primary"
        >
          Core
        </div>
        <div
          class="mb-5 flex h-12 w-12 items-center justify-center rounded-[14px] bg-[rgba(59,130,246,0.15)] text-[22px]"
        >
          📋
        </div>
        <h3 class="mb-2 font-display text-2xl font-semibold text-white">
          Gestion de reservas inteligente
        </h3>
        <p class="text-base leading-relaxed text-gray-400">
          Visualiza, confirma y gestiona todas las reservas en un solo lugar.
          Soporte para hasta 4 jugadores por cancha, calendario visual y
          deteccion de conflictos.
        </p>

        <!-- Booking preview mockup -->
        <div
          class="mt-8 rounded-xl border border-white/[0.06] bg-gray-800 p-5"
        >
          {
            bookingPreview.map((booking, i) => (
              <div
                class:list={[
                  "flex items-center gap-3 py-2.5",
                  i < bookingPreview.length - 1 &&
                    "border-b border-white/[0.04]",
                ]}
              >
                <div
                  class={`flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br ${booking.gradient} text-xs font-semibold text-white`}
                >
                  {booking.initials}
                </div>
                <div class="flex-1">
                  <div class="text-[13px] font-medium text-white">
                    {booking.name}
                  </div>
                  <div class="text-[11px] text-gray-500">{booking.meta}</div>
                </div>
                <div
                  class:list={[
                    "rounded-md px-2.5 py-1 text-[11px] font-semibold",
                    booking.statusType === "confirmed"
                      ? "bg-[rgba(16,185,129,0.12)] text-secondary"
                      : "bg-[rgba(245,158,11,0.12)] text-warning",
                  ]}
                >
                  {booking.status}
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Small feature cards -->
      {
        smallFeatures.map((feature) => (
          <div class="group relative overflow-hidden rounded-[20px] border border-gray-200 bg-white p-8 transition-all duration-300 hover:-translate-y-1 hover:border-primary hover:shadow-[0_8px_32px_rgba(59,130,246,0.08)]">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-[14px] bg-primary-100 text-[22px]">
              {feature.icon}
            </div>
            <h3 class="mb-2 font-display text-lg font-semibold text-gray-900">
              {feature.title}
            </h3>
            <p class="text-sm leading-relaxed text-gray-500">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
