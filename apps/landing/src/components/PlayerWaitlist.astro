---
import WaitlistForm from "./WaitlistForm";
---

<section class="bg-gray-50 px-8 py-24" id="waitlist">
  <div class="mx-auto max-w-[700px] text-center">
    <div
      class="mb-5 inline-flex items-center gap-2 rounded-full bg-secondary/10 px-4 py-1.5 text-[13px] font-medium text-secondary"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"
        ></path>
      </svg>
      Proximamente
    </div>

    <h2
      class="mb-4 font-display text-3xl font-bold leading-tight tracking-tight text-gray-900 lg:text-[40px]"
    >
      Se de los primeros en usar la app
    </h2>
    <p class="mx-auto mb-10 max-w-[540px] text-[17px] leading-relaxed text-gray-500">
      Estamos construyendo la app de PadelHub para que reserves canchas,
      encuentres jugadores y mas. Dejanos tus datos y te avisaremos cuando este
      lista.
    </p>

    <WaitlistForm client:visible />
  </div>
</section>
