# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to \`.env\`.

# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# =============================================================================
# DATABASE
# =============================================================================
# For LOCAL development (Supabase local):
POSTGRES_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# For PRODUCTION (Supabase cloud):
# POSTGRES_URL="postgres://postgres.[USERNAME]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?workaround=supabase-pooler.vercel"


# You can generate the secret via 'openssl rand -base64 32' on Unix
# @see https://www.better-auth.com/docs/installation
AUTH_SECRET='supersecret'

# OAuth providers (to be configured for production)
# @see https://www.better-auth.com/docs/authentication/google
# AUTH_GOOGLE_ID=''
# AUTH_GOOGLE_SECRET=''
# @see https://www.better-auth.com/docs/authentication/apple
# AUTH_APPLE_ID=''
# AUTH_APPLE_SECRET=''

# =============================================================================
# EMAIL (Resend)
# =============================================================================
# Optional in dev — emails will be logged to console if not set
# @see https://resend.com/api-keys
# RESEND_API_KEY=''

# =============================================================================
# ADMIN APP — Site Protection
# =============================================================================
# Site-level password gate (disabled when unset — local dev skips gate entirely)
# ADMIN_SITE_PASSWORD=''

# Upstash Redis for API rate limiting (disabled when unset)
# @see https://upstash.com/docs/redis/overall/getstarted
# UPSTASH_REDIS_REST_URL=''
# UPSTASH_REDIS_REST_TOKEN=''

# =============================================================================
# CRON (Vercel)
# =============================================================================
# Shared secret for the keep-alive cron route at /api/cron/keep-alive (apps/nextjs).
# Vercel auto-injects this header on cron triggers when the env var is set.
# Generate with: openssl rand -hex 32
# CRON_SECRET=''

# =============================================================================
# CLOUDFLARE IMAGES
# =============================================================================
# @see https://developers.cloudflare.com/images/
# Account ID: found in Cloudflare Dashboard sidebar
CLOUDFLARE_ACCOUNT_ID=''
# Account Hash: found under Images > Overview > Developer Resources (used in delivery URLs)
CLOUDFLARE_IMAGES_HASH=''
# API Token: create with "Cloudflare Images:Edit" permission
CLOUDFLARE_IMAGES_TOKEN=''
# Public hash for Next.js client-side image URLs (same value as CLOUDFLARE_IMAGES_HASH)
NEXT_PUBLIC_CLOUDFLARE_IMAGES_HASH=''