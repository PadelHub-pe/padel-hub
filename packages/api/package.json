{
  "name": "@wifo/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./lib/keep-alive": {
      "types": "./dist/lib/keep-alive.d.ts",
      "default": "./src/lib/keep-alive.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@trpc/server": "catalog:",
    "@upstash/ratelimit": "catalog:",
    "@upstash/redis": "catalog:",
    "@wifo/auth": "workspace:*",
    "@wifo/db": "workspace:*",
    "@wifo/email": "workspace:*",
    "@wifo/images": "workspace:*",
    "@wifo/validators": "workspace:*",
    "@wifo/whatsapp": "workspace:*",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.44.7",
    "superjson": "2.2.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "catalog:",
    "@wifo/eslint-config": "workspace:*",
    "@wifo/prettier-config": "workspace:*",
    "@wifo/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "prettier": "@wifo/prettier-config"
}
