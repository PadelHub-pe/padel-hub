{
  "name": "@wifo/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./src/client.ts"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./src/schema.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "push": "pnpm with-env drizzle-kit push",
    "create-admin": "pnpm with-env tsx src/create-admin.ts",
    "seed": "pnpm with-env tsx src/seed.ts",
    "migrate:owner-accounts": "pnpm with-env tsx src/migrate-owner-accounts.ts",
    "studio": "pnpm with-env drizzle-kit studio",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "better-auth": "catalog:",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "postgres": "^3.4.8",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@wifo/eslint-config": "workspace:*",
    "@wifo/prettier-config": "workspace:*",
    "@wifo/tsconfig": "workspace:*",
    "drizzle-kit": "^0.31.5",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  },
  "prettier": "@wifo/prettier-config"
}
